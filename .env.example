# Copy to .env (gitignored) and set for your bench. Never commit real addresses.
# LAN (VXI-11):   TCPIP0::<ip>::INSTR
# LAN (socket):   TCPIP0::<ip>::4000::SOCKET
# USB:            USB0::0x0699::<product>::<serial>::INSTR   (0x0699 = Tektronix)

SCOPE_RESOURCE=TCPIP0::192.168.0.10::INSTR
AFG_RESOURCE=TCPIP0::192.168.0.11::INSTR
